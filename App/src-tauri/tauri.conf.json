{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EcoAlert",
  "version": "1.0.0",
  "identifier": "com.ecoalert.monitor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EcoAlert · 视频监控",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "additionalBrowserArgs": "--disable-features=BlockInsecurePrivateNetworkRequests,InsecurePrivateNetworkSubresourceRequests"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' http://127.0.0.1:* http://localhost:* https: ws: wss:; media-src 'self' http://127.0.0.1:* http://localhost:* https: blob: data:; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
